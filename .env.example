# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# --- Optional: future backend integration ---
# This app currently ships with NO backend server: login is a local/simulated
# profile, Premium is verified directly against Google Play Billing (see
# BillingManager.kt), and QR generation/scanning run entirely on-device
# (ZXing) with no network call. Nothing below is required to build or run
# the app today.
#
# If you later add a backend (e.g. for dynamic/trackable QR redirects, or to
# swap the simulated login for real server-issued sessions), point the app
# at it here instead of hardcoding the URL in source. Leave blank to keep
# using local-only behavior. Every field here is a non-secret base URL —
# real credentials (DB passwords, Play Developer API service-account keys,
# Stripe secret keys, JWT signing secrets, etc.) must live on the server
# only and must NEVER be added to this file, since it ships inside the app.
DYNAMIC_QR_API_BASE_URL=
AUTH_API_BASE_URL=
